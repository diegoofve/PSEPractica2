generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model movie {
  id     Int    @id @default(autoincrement())
  name   String @db.VarChar(50)
  actors String @db.VarChar(200)
}

model points {
  id     Int @id @default(autoincrement())
  points Int
}

model sales {
  id     Int   @id @default(autoincrement())
  amount Float
}

model show_timing {
  id         Int      @id @default(autoincrement())
  day        DateTime @db.Date
  theater_id Int
  movie_id   Int
  timing_id  Int
}

model theater {
  id       Int    @id @default(autoincrement())
  name     String @db.VarChar(50)
  capacity Int
}

model timeslot {
  id         Int    @id @default(autoincrement())
  start_time String @db.VarChar(5)
  end_time   String @db.VarChar(5)
}
